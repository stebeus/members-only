<!doctype html>
<html lang="en">
	<%- include('partials/metadata', locals.title) %>
	<body>
		<div id="root" class="grid grid-template-root">
			<%- include('partials/navbar') %>
			<main class="border-bottom border-top flex flex-col gap-m p-m">
				<% if (locals.user == null) { %>
					<p><a href="/sign-up">Sign up</a> to create posts.</p>
				<% } else { %>
					<p class="center-text">Welcome, <%= user.full_name %>!</p>

					<% if (!user.is_member) { %>
						<p>
							<a href="/join-the-club">Join the club</a>
							to see usernames and dates.
						</p>
        	<% } %>
				<% } %>

				<ul class="flex flex-col gap-m">
					<% for (const post of posts) { %>
						<li><%- include('partials/post', { post }) %></li>
					<% } %>
				</ul>
			</main>
			<%- include('partials/footer') %>
		</div>
	</body>
</html>
