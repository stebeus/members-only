<!doctype html>
<html lang="en">
	<%- include('partials/metadata', locals.title) %>
	<body>
		<div id="root">
			<h1><%= err.status ?? 500 %></h1>
			<p><%= err.message %></p>
      <%- include('partials/button-link', { href: '/', label: 'Go back home' }) %>
			<% if (nodeEnv !== 'production') { %>
			  <pre><%= err.stack %></pre>
			<% } %>
		</div>
	</body>
</html>
