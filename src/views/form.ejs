<!doctype html>
<html lang="en">
	<%- include('partials/metadata', locals.title) %>
	<body>
		<div id="root" class="grid grid-template-root">
			<%- include('partials/navbar') %>
			<main
				class="border-bottom border-top flex flex-col center-content gap-m p-m"
			>
				<fieldset class="border p-xl">
					<legend><%= locals.title %></legend>

					<form
						class="flex flex-col gap-xl"
						action="<%= action %>"
						method="post"
					>
						<% if (locals.errs != null) {%>
							<ul class="errors">
								<% for (const err of errs) { %>
									<li class="error"><%= err.msg ?? err %></li>
								<% } %>
							</ul>
						<% } %>

						<% for (const input of inputs) { %>
							<%- include('partials/form/input-field', input) %>
						<% } %>

						<% if (locals.hasTextarea) {%>
							<%- include('partials/form/textarea-field', textarea) %>
						<% } %>

						<%- include('partials/form/button', { label: submissionLabel }) %>
					</form>
				</fieldset>
			</main>
			<%- include('partials/footer') %>
		</div>
	</body>
</html>
