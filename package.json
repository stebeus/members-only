{
	"name": "members-only",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"imports": {
		"#root/*": "./src/*"
	},
	"scripts": {
		"init-db": "node src/db/init-db.js",
		"lint": "biome check --fix",
		"serve": "node --watch src/server.js",
		"start": "pnpm init-db & pnpm serve",
		"test": "node --test --watch"
	},
	"dependencies": {
		"@vinejs/vine": "^4.4.0",
		"ejs": "^5.0.2",
		"express": "^5.2.1",
		"express-session": "^1.19.0",
		"http-errors": "^2.0.1",
		"passport": "^0.7.0",
		"passport-local": "^1.0.0",
		"pino-http": "^11.0.0",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"pino-pretty": "^13.1.3"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.1.2",
			"onFail": "download"
		}
	}
}
